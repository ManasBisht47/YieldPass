{
  "name": "@yieldpass/contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/**/*.test.ts",
    "test:integration": "hardhat test test/integration/**/*.test.ts",
    "deploy:testnet": "hardhat deploy --network qie-testnet",
    "deploy:mainnet": "hardhat deploy --network qie-mainnet",
    "verify": "ts-node scripts/verify-contracts.ts",
    "lint": "solhint 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "hardhat": "^2.22.0",
    "hardhat-deploy": "^0.12.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solhint": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "@types/node": "^20.0.0",
    "chai": "^4.4.0",
    "@types/chai": "^4.3.0"
  }
}
