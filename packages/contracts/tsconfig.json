{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["hardhat.config.ts", "deploy/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}
