# ── Network ───────────────────────────────────────────────────────────
RPC_URL=https://rpc1testnet.qie.digital/
CHAIN_ID=1983

# ── Keys (NEVER commit real values; use a secrets manager in prod) ────
# Keeper: KEEPER_ROLE on YieldStrategy + runs harvest/inject
KEEPER_PRIVATE_KEY=
# Funder: testnet seeding + UPDATER_ROLE on PriceOracle (bounded price pushes)
FUNDER_PRIVATE_KEY=
# Admin: DEFAULT_ADMIN_ROLE — on mainnet leave UNSET here
# (admin moves to a multisig via contracts/scripts/transfer-admin.ts)
ADMIN_PRIVATE_KEY=

# ── Contract addresses ─────────────────────────────────────────────────
YIELD_STRATEGY_ADDRESS=
YIELD_VAULT_ADDRESS=
WQIE_ADDRESS=
QUSDC_ADDRESS=
LENDING_POOL_ADDRESS=
PRICE_ORACLE_ADDRESS=

# ── Yield schedule ──────────────────────────────────────────────────────
# Mainnet: real harvestAndDistribute, daily at midnight UTC
HARVEST_CRON=0 0 * * *
# Testnet only: target base APY for simulated yield (750 = 7.5%)
TARGET_APY_BPS=750
# Fallback fixed inject when TARGET_APY_BPS unset (18 decimals — 0.1 QIE)
SIMULATE_YIELD_AMOUNT=100000000000000000

# ── Price keeper (oracle ↔ CoinGecko sync) ─────────────────────────────
PRICE_CRON=*/5 * * * *
PRICE_DEVIATION_BPS=50
PRICE_MAX_STALENESS_SEC=3600
