{
  "name": "@yieldpass/keeper",
  "version": "1.0.0",
  "private": true,
  "description": "YieldPass keeper bot \u2014 daily harvest and yield injection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
